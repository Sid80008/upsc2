{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preparation settings, behavioral data, and mastery levels.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "daily_study_hours": { "type": "integer" },
        "current_affairs_weight": { "type": "integer" },
        "focus_level": { "type": "string" },
        "distraction_level": { "type": "string" },
        "weak_subjects": { "type": "string" },
        "strong_subjects": { "type": "string" },
        "streak": { "type": "number" },
        "xp": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "StudyBlock": {
      "title": "Study Block",
      "description": "A single scheduled study session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "partially_completed", "missed"] },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["userId", "subject", "startTime", "durationMinutes", "status"]
    },
    "DailyReport": {
      "title": "Daily Report",
      "description": "End-of-day summary of study performance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "plannedBlocks": { "type": "number" },
        "completedBlocks": { "type": "number" },
        "distractionMinutes": { "type": "number" },
        "focusScore": { "type": "number" },
        "verified": { "type": "boolean" }
      },
      "required": ["userId", "date", "verified"]
    },
    "Note": {
      "title": "Knowledge Hub Note",
      "description": "User notes and study materials.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings."
    },
    "/studyBlocks/{blockId}": {
      "schema": "StudyBlock",
      "description": "Scheduled study sessions for all users."
    },
    "/dailyReports/{reportId}": {
      "schema": "DailyReport",
      "description": "Performance reports for all users."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Knowledge hub entries."
    }
  }
}
